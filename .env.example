# ===== Stone Memory environment variables =====
# Copy to .env.local and fill in actual values for each environment.

# Public site URL (used in metadata, canonical URLs, sitemap)
NEXT_PUBLIC_SITE_URL=https://stonememory.com

# ===== Telegram chat bridge =====
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Numeric chat ID of the admin group/channel
TELEGRAM_ADMIN_CHAT_ID=
# Shared secret set via Telegram setWebhook — verified on /api/telegram
TELEGRAM_WEBHOOK_SECRET=

# ===== Google Reviews (optional) =====
# Server-only key used by /api/reviews to fetch Google Places reviews
GOOGLE_PLACES_API_KEY=
# Place ID for the business
GOOGLE_PLACE_ID=

# ===== Search console verifications (optional) =====
GOOGLE_VERIFICATION=
BING_VERIFICATION=
YANDEX_VERIFICATION=

# ===== Error tracking (optional) =====
# Sentry DSN for client + server error reporting
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ===== Analytics (optional) =====
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

